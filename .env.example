# Required on Vercel and local development.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
AUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTE_SECRET"

# Required when using NextAuth callbacks. Use your Vercel/custom domain in production.
NEXTAUTH_URL="https://your-vercel-app.vercel.app"
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTE_SECRET"

# Optional app URL values for callbacks, links, or future server-side absolute URLs.
NEXT_PUBLIC_APP_URL="https://your-vercel-app.vercel.app"
AUTH_URL="https://your-vercel-app.vercel.app"
APP_BASE_URL="https://your-vercel-app.vercel.app"

# Future integrations
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
